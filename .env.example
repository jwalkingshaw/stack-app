# Runtime
NODE_ENV=development

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_TENANT_BASE_DOMAIN=stackcess.com
NEXT_PUBLIC_HELP_CENTER_URL=https://help.stackcess.com
NEXT_PUBLIC_KINDE_PRICING_TABLE_KEY=organization_plans

# Supabase (shared)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Kinde Auth (shared)
KINDE_CLIENT_ID=your_kinde_client_id
KINDE_CLIENT_SECRET=your_kinde_client_secret
KINDE_ISSUER_URL=https://your-subdomain.kinde.com
KINDE_SITE_URL=http://localhost:3001
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:3001
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3001/dashboard

# Kinde Management API (SaaS org + role sync)
KINDE_MANAGEMENT_API_DOMAIN=https://your-subdomain.kinde.com
KINDE_MANAGEMENT_API_AUDIENCE=https://your-subdomain.kinde.com/api
KINDE_MANAGEMENT_CLIENT_ID=your_kinde_management_client_id
KINDE_MANAGEMENT_CLIENT_SECRET=your_kinde_management_client_secret
# Space-separated scopes
KINDE_MANAGEMENT_EXTRA_SCOPES=read:roles read:organization_user_roles create:organization_user_roles delete:organization_user_roles
KINDE_BILLING_ADMIN_ROLE_KEY=org_billing_admin
# Optional explicit mapping, example: sandbox-plan:free,starter-v1:starter
KINDE_BILLING_PLAN_MAP=

# AWS S3 / CloudFront (SaaS assets)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-southeast-2
# Optional alias used by some utility code
AWS_DEFAULT_REGION=ap-southeast-2
AWS_S3_BUCKET=your_s3_bucket_name
# Optional alias used by some utility code
AWS_S3_BUCKET_NAME=your_s3_bucket_name
# CloudFront hostname only (no protocol)
AWS_CLOUDFRONT_DOMAIN=dxxxxxx.cloudfront.net
# Optional S3 debug flag
DEBUG_S3_SERVICE=false

# Redis caches
REDIS_URL=redis://localhost:6379
REDIS_URL_SAAS=redis://localhost:6379

# Email delivery
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@stackcess.com

# Localization / AI
DEEPL_API_KEY=your_deepl_api_key
# Optional override (defaults to api-free for :fx keys, api.deepl.com otherwise)
DEEPL_API_BASE_URL=
# sync | async (default sync)
LOCALIZATION_JOB_EXECUTION_MODE=sync

# Scheduled update processor
UPDATES_SCHEDULER_SECRET=replace_with_strong_random_secret

# Partner grant cache tuning (optional)
PARTNER_GRANT_CACHE_TTL_MS=60000
PARTNER_GRANT_CACHE_MAX_KEYS=10000

# Sanity (marketing site + studio)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_STUDIO_PROJECT_ID=your_sanity_project_id
SANITY_STUDIO_DATASET=production
